# Node
node_modules/
npm-debug.log*

# Environment
.env

# Live-bill outputs need provider keys and are not reproducible in CI, so they
# are not committed. The accounting results (control.json / optimized.json) ARE
# committed — they are the real, reproducible scores.
**/results/live-bill.json

# Local optimizer scratch
optimizer.config.json
optimizer-settings-audit.log

# Optimized request bodies stashed by run_benchmark for the quality runner to
# reuse — derived (synthetic) content, so not committed.
**/results/optimized-requests.local.json

# macOS
.DS_Store

# Intermediate judge dumps (regenerate with --dump)
**/results/judge-inputs.json
