# Anyray optimizer benchmarks — environment
#
# The benchmarks run against a LIVE Anyray optimizer (the before-request hook),
# the same way a compression benchmark runs against a hosted compression API.
# Bring one up with the Anyray stack (`docker compose up` exposes it in-network
# on :8088) or point at any reachable instance.

# Where the optimizer is reachable.
ANYRAY_OPTIMIZER_URL=http://localhost:8088

# Admin token for /admin/optimizer/settings — the harness uses it to pin one
# strategy at one knob per workload. Same key that gates the Anyray console.
ANYRAY_ADMIN_TOKEN=your-admin-token-here

# Optimizer hook token — only needed if the target optimizer sets
# ANYRAY_OPTIMIZER_TOKEN (hardened deployments gate /v1/optimize behind it).
# Leave unset for a default dev/docker optimizer, which leaves the hook open.
# ANYRAY_OPTIMIZER_TOKEN=your-optimizer-token-here

# --- Optional: LLM judge for the quality benchmark (node run_quality.mjs --judge) ---
# Any OpenAI-compatible /chat/completions endpoint. Set ANYRAY_JUDGE_MODEL to the
# model you want credited in quality.json (the committed numbers used Claude Opus 4.8).
# ANYRAY_JUDGE_URL=http://localhost:8787/v1
# ANYRAY_JUDGE_KEY=your-judge-key-here
# ANYRAY_JUDGE_MODEL=claude-opus-4-8

# Live validation (run_live.mjs)
ANYRAY_GATEWAY_URL=http://localhost:8787
ANYRAY_LIVE_MODEL=claude-sonnet-4-6

# Live auth (run_live.mjs). Defaults: passthrough mode, client key from ~/.anyray/connect.json,
# subscription OAuth read from the macOS keychain at run time. Override to use an API key:
# ANYRAY_AUTH_MODE=passthrough        # or 'managed' if the gateway has a server-side credential
# ANYRAY_PROVIDER=anthropic
# ANYRAY_CLIENT_KEY=ark_...           # else read from ~/.anyray/connect.json
# ANYRAY_UPSTREAM_TOKEN=sk-ant-...    # passthrough credential; else read from keychain
